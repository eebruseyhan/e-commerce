# Kopyala: cp .env.example .env  →  sonra kendi değerlerinle doldur

# ── Veritabanı (Docker & Yerel) ──────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=degistir_bunu
POSTGRES_DB=ecomm

# ── Backend ───────────────────────────────────────────────
PORT=5001
DATABASE_URL=postgresql://postgres:degistir_bunu@localhost:5432/ecomm

# ── Güvenlik ──────────────────────────────────────────────
JWT_SECRET=buraya_uzun_ve_rastgele_bir_kelime_yaz
