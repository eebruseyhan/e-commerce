# Sunucunun çalışacağı port. Değiştirmene gerek yok, 5000 bırakabilirsin.
PORT=5000

# PostgreSQL bağlantı adresi.
# Formatı: postgresql://KULLANICI:SIFRE@HOST:PORT/VERITABANI
#
# Adımlar:
# 1. PostgreSQL'i kur ve başlat:
#      Mac:     brew install postgresql && brew services start postgresql
#      Windows: https://www.postgresql.org/download/windows/
#
# 2. Veritabanı oluştur (terminalde):
#      psql -U postgres
#      CREATE DATABASE ecommerce;
#      \q
#
# 3. Aşağıdaki bilgileri kendi bilgisayarına göre doldur:
#      KULLANICI → psql kullanıcı adın (genelde "postgres")
#      SIFRE     → kurulum sırasında belirlediğin şifre (yoksa boş bırak)
#      PORT      → varsayılan 5432
#      VERITABANI→ az önce oluşturduğun veritabanı adı (örn: ecommerce)
#
# Örnek:
#   DATABASE_URL=postgresql://postgres:sifre123@localhost:5432/ecommerce
#   DATABASE_URL=postgresql://postgres:@localhost:5432/ecommerce  (şifresiz)
DATABASE_URL=postgresql://KULLANICI:SIFRE@localhost:5432/VERITABANI

# Tabloları oluşturmak için kurulumdan sonra şunu çalıştır:
#   npm run migrate

# JWT token imzalama anahtarı.
# İstediğin herhangi bir uzun ve rastgele bir kelime/cümle yazabilirsin.
# Örnek: mysecretkey123  veya  super_gizli_anahtar_2024
JWT_SECRET=buraya_gizli_bir_kelime_yaz